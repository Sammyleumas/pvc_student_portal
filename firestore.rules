rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened global helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 2. Students Collection
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow write: if (isOwner(studentId) || isAdmin()) && isValidId(studentId);
    }

    // 3. Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(adminId);
    }

    // 4. Audit Logs Collection
    match /auditLogs/{logId} {
      allow read, write: if isAdmin() && isValidId(logId);
    }

    // 5. Quizzes Collection
    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow write: if (isAdmin() || (isSignedIn() && request.resource.data.student_id == request.auth.uid)) && isValidId(quizId);
    }

    // 6. Submissions Collection
    match /submissions/{submissionId} {
      allow read: if isSignedIn();
      allow write: if (isAdmin() || (isSignedIn() && request.resource.data.student_id == request.auth.uid)) && isValidId(submissionId);
    }

    // 7. Settings Collection
    match /settings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(settingsId);
    }

    // 8. Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(notificationId);
    }
  }
}
